# Your OpenAI API key from https://platform.openai.com/api-keys
API_KEY="your_openai_api_key_here"

# Bearer access token for authenticating with the MCP server
# For Entra-protected deployments, acquire this for your MCP API app registration.
MCP_ACCESS_TOKEN="your_access_token_here"
MCP_SERVER_URL="https://your_remote_mcp_server_url_here"