{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "mcpContainerTsExists": {
        "value": "${SERVICE_MCP_CONTAINER_TS_RESOURCE_EXISTS=false}"
      },
      "principalId": {
        "value": "${AZURE_PRINCIPAL_ID}"
      },
      "mcpServerIngressPort": {
        "value": "${MCP_SERVER_INGRESS_PORT=3000}"
      },
      "resourceServerUrl": {
        "value": "${RESOURCE_SERVER_URL=}"
      },
      "tenantId": {
        "value": "${TENANT_ID=}"
      },
      "mcpResourceAppId": {
        "value": "${MCP_RESOURCE_APP_ID=}"
      },
      "mcpScope": {
        "value": "${MCP_SCOPE=access_as_user}"
      },
      "graphOboScope": {
        "value": "${GRAPH_OBO_SCOPE=https://graph.microsoft.com/User.Read}"
      },
       "resourceTags": {
        "value": {
          "owner": "Aslam",
          "createdate": "2026-03-10",
          "removedate": "2026-04-30",
          "salesorcompdev": "compdev",
          "opportunity": "OPP-ADA"
        }
      }
    }
}
